{
    "name": "audreyhalder/plugin-generator",
    "description": "CLI tool that scaffolds a Shopware 6 plugin skeleton from a single command.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Audrey Halder",
            "email": "audreyhalder98@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "symfony/console": "^6.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.9",
        "phpstan/phpstan": "^1.11"
    },
    "autoload": {
        "psr-4": {
            "PluginGenerator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PluginGenerator\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/plugin-generator"
    ],
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
